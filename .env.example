# Copy to .env and fill in. .env is gitignored.

HOME_ADDR=203.0.113.10      # your home IP or DNS name (port-forwarded on the router)
HOME_PORT=8080              # the HTTP/2 (h2c) port your home receiver listens on
LISTEN_PORT=443            # the port clients hit on the VPS
CONCURRENCY=1              # Envoy worker threads = max upstream conns to home (keep 1)
